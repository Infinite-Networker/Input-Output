# =====================================================
# Input-Output Platform — Environment Variables
# Created by Cherry Computer Ltd.
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to Git.
# =====================================================

# Application
IO_APP_ENV=development
IO_APP_PORT=8000
IO_SECRET_KEY=change-me-to-a-random-256-bit-secret
IO_API_KEY=your-api-key-for-local-testing

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Input-Output

# Database (PostgreSQL)
DATABASE_URL=postgresql://iouser:iopass@localhost:5432/inputoutput
DATABASE_POOL_SIZE=10

# Search Engine (Elasticsearch)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=input_output_papers

# Cache (Redis)
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# External Repository APIs
ARXIV_API_RATE_LIMIT=3
PUBMED_API_KEY=your-pubmed-api-key
DOAJ_API_KEY=your-doaj-api-key

# Authentication
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Monitoring (optional)
SENTRY_DSN=
LOG_LEVEL=INFO
